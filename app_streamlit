import streamlit as st
import streamlit.components.v1 as components
import os

st.set_page_config(
    page_title="MediCare – Integrated Healthcare Dashboard",
    page_icon="🏥",
    layout="wide",
    initial_sidebar_state="collapsed",
)

st.markdown("""
<style>
    #MainMenu, header, footer { visibility: hidden; height: 0; }
    .block-container { padding: 0 !important; max-width: 100% !important; }
    section[data-testid="stSidebar"] { display: none; }
</style>
""", unsafe_allow_html=True)

HTML_PATH = os.path.join(os.path.dirname(__file__), "healthcare_dashboard.html")
with open(HTML_PATH, "r", encoding="utf-8") as f:
    html_content = f.read()

# Inject the Anthropic API key from Streamlit secrets into the HTML
api_key = st.secrets.get("ANTHROPIC_API_KEY", "")
html_content = html_content.replace(
    "headers: { 'Content-Type': 'application/json' }",
    f"headers: {{ 'Content-Type': 'application/json', 'x-api-key': '{api_key}', 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true' }}"
)

components.html(html_content, height=3800, scrolling=True)
