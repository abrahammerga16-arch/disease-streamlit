import streamlit as st
import streamlit.components.v1 as components
import os

st.set_page_config(
    page_title="MediCare – Integrated Healthcare Dashboard",
    page_icon="🏥",
    layout="wide",
    initial_sidebar_state="collapsed",
)

st.markdown("""
<style>
    #MainMenu, header, footer { visibility: hidden; height: 0; }
    .block-container { padding: 0 !important; max-width: 100% !important; }
    section[data-testid="stSidebar"] { display: none; }
</style>
""", unsafe_allow_html=True)

# Get Groq API key from Streamlit secrets
try:
    groq_key = st.secrets["GROQ_API_KEY"]
except Exception:
    groq_key = ""

# Load HTML file
HTML_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "healthcare_dashboard.html")

try:
    with open(HTML_PATH, "r", encoding="utf-8") as f:
        html_content = f.read()
except FileNotFoundError:
    st.error("healthcare_dashboard.html not found. Please upload it to your GitHub repo.")
    st.stop()

# Inject Groq API key
html_content = html_content.replace("YOUR_GROQ_API_KEY_HERE", groq_key)

components.html(html_content, height=3800, scrolling=True)
